SHOPIFY_STORE_DOMAIN=your-development-store.myshopify.com
SHOPIFY_API_KEY=replace_me
SHOPIFY_API_SECRET=replace_me
SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_replace_me
SHOPIFY_API_VERSION=2026-01

# Keep true until you have verified the generated files and store target.
DRY_RUN=true

# Set true only when you intend to delete records tagged seeded_by_retention_app.
DELETE_SEEDED_DATA=false

SHOPIFY_TIMEOUT_SECONDS=45
SHOPIFY_MAX_RETRIES=5
SHOPIFY_RETRY_BASE_DELAY=1.0
SEED_DATA_DIR=data
# Local dev can use SQLite. Production should use Postgres and run `alembic upgrade head`.
DATABASE_URL=sqlite:///./app.db
# Example production value:
# DATABASE_URL=postgresql://user:password@host:5432/styleiq
# Optional migration-only override. Useful when a local `.env` points at SQLite.
ALEMBIC_DATABASE_URL=
PUBLIC_APP_URL=https://xxxx.ngrok.io
TRACKING_SCRIPT_URL=https://xxxx.ngrok.io/public/tracker.js

# App dashboard/API auth. Generate a long random value for production.
ENVIRONMENT=development
APP_AUTH_SECRET_KEY=replace_with_32_plus_random_chars
APP_AUTH_TOKEN_TTL_MINUTES=1440
INTERNAL_ADMIN_TOKEN=
EXTERNAL_RETRY_MAX_ATTEMPTS=3
EXTERNAL_RETRY_BASE_DELAY_SECONDS=0.75
PUBLIC_RATE_LIMIT_ENABLED=true
PUBLIC_RATE_LIMIT_PER_MINUTE=120
DEAD_LETTER_DIR=data/dead_letters

NANGO_BASE_URL=http://localhost:3005
NANGO_SECRET_KEY=
NANGO_PUBLIC_KEY=
NANGO_ENVIRONMENT=dev
NANGO_TIMEOUT_SECONDS=30
NANGO_PROVIDER_CONFIG_KEY=shopify
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_SCOPES=read_products,read_customers,read_orders,read_inventory,read_script_tags,write_script_tags

GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TIMEOUT_SECONDS=30
GROQ_MAX_RETRIES=2

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GMAIL_SENDER_EMAIL=adityapalghar@gmail.com
GMAIL_REFRESH_TOKEN=
GMAIL_REDIRECT_URI=http://127.0.0.1:8010/gmail/oauth/callback
GMAIL_SEND_SCOPE=https://www.googleapis.com/auth/gmail.send https://www.googleapis.com/auth/gmail.modify
GMAIL_TIMEOUT_SECONDS=30

# Outfit image generation. GPT_IMAGE_KEY is preferred.
GPT_IMAGE_KEY=
IMAGE_API_KEY=
IMAGE_API_BASE_URL=https://api.evolink.ai/v1/images/generations
IMAGE_TASK_BASE_URL=https://api.evolink.ai/v1/tasks
IMAGE_MODEL=gpt-image-2
IMAGE_SIZE=1024x640
IMAGE_RESOLUTION=1K
IMAGE_QUALITY=low
IMAGE_TIMEOUT_SECONDS=90
IMAGE_POLL_INTERVAL_SECONDS=5
IMAGE_MAX_WAIT_SECONDS=240
IMAGE_MAX_CREDITS_PER_TASK=1.2
IMAGE_MAX_REFERENCE_URLS=0
IMAGE_PROVIDER=evolink

# Retention intelligence providers.
FASHIONCLIP_PROVIDER=local_hash
FASHIONCLIP_EMBEDDING_DIMENSIONS=384
VECTOR_CACHE_THRESHOLD=0.92

# Optional Seedream V4 through RunPod Serverless. Set IMAGE_PROVIDER=runpod_seedream to use.
RUNPOD_API_KEY=
RUNPOD_SEEDREAM_ENDPOINT_ID=
RUNPOD_BASE_URL=https://api.runpod.ai/v2
RUNPOD_TIMEOUT_SECONDS=120
RUNPOD_MAX_WAIT_SECONDS=300
RUNPOD_POLL_INTERVAL_SECONDS=5

# Email delivery. Local testing can keep gmail; production should use sendgrid.
RETENTION_SENDER_PROVIDER=gmail
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_FROM_NAME=Aevnai
SENDGRID_BASE_URL=https://api.sendgrid.com/v3
SENDGRID_TIMEOUT_SECONDS=30
