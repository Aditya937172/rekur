# RECURING Environment Configuration Template
# Copy this file to .env and fill in your values

# === APPLICATION ===
ENVIRONMENT=development
DRY_RUN=true
PUBLIC_APP_URL=http://localhost:8000

# === DATABASE ===
DATABASE_URL=sqlite:///./app.db
# For production:
# DATABASE_URL=postgresql://rekur:password@localhost:5432/rekur

# === REDIS (Celery Queue) ===
REDIS_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# === SHOPIFY ===
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_ADMIN_ACCESS_TOKEN=
SHOPIFY_API_VERSION=2026-01
SHOPIFY_WEBHOOK_SECRET=

# === GROQ (LLM) ===
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# === IMAGE GENERATION ===
IMAGE_PROVIDER=evolink
GPT_IMAGE_KEY=
IMAGE_MODEL=gpt-image-2

# === RUNPOD (Seedream) ===
RUNPOD_API_KEY=
RUNPOD_SEEDREAM_ENDPOINT_ID=

# === GMAIL OAUTH ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GMAIL_SENDER_EMAIL=
GMAIL_REFRESH_TOKEN=

# === SENDGRID (Alternative Email) ===
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_FROM_NAME=RECURING

# === SENTRY (Error Tracking) ===
SENTRY_DSN=

# === NANGO (OAuth Proxy) ===
NANGO_SECRET_KEY=
NANGO_PUBLIC_KEY=
NANGO_CONNECTION_ID=

# === VECTOR CACHE ===
VECTOR_CACHE_THRESHOLD=0.92
FASHIONCLIP_EMBEDDING_DIMENSIONS=384
